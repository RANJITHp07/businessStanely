datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id        String    @id @default(auto()) @map("_id") @db.ObjectId
  username  String    @unique
  email     String    @unique
  password  String
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  comments  Comment[] @relation("UserComments")  // Add this relation
  
  // OTP fields for password reset
  resetOtp       String?
  otpExpiry      DateTime?
  isOtpVerified  Boolean @default(false)
}

// ... other models remain the same ...

model Comment {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  content   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // File attachment fields
  attachmentName String?
  attachmentUrl  String?
  attachmentSize Int?
  attachmentType String?

  taskId String @db.ObjectId
  task   Task   @relation(fields: [taskId], references: [id], onDelete: Cascade)

  authorType String  // "USER" or "AGENT"
  authorId   String  @db.ObjectId
  user       User?   @relation("UserComments", fields: [authorId], references: [id])
  agent      Agent?  @relation("AgentComments", fields: [authorId], references: [id])
}