model Prospect {
  id            String   @id @default(auto()) @map("_id") @db.ObjectId
  name          String
  email         String?
  dialCode      String?
  phoneNumber   String?
  description   String?
  amount        Float?
  address        String?
  status        String   @default("New") // e.g., New, Contacted, Qualified, Lost, Converted
  notes         String?
  nextFollowUp  DateTime?
  prevFollowup  DateTime?
  assignedAgentId String? @db.ObjectId
  assignedAgent   Agent?  @relation("AgentAssignedProspects", fields: [assignedAgentId], references: [id])
  createdByAgentId String? @db.ObjectId
  createdByAgent   Agent?  @relation("AgentCreatedProspects", fields: [createdByAgentId], references: [id])
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  opportunities Opportunity[] @relation("ProspectOpportunities")
  archived      Boolean  @default(false) // If true, this prospect is archived (e.g., converted to opportunity)
  leadSourceId   String?
  leadSource     LeadSource? @relation(fields: [leadSourceId], references: [id])
  comments      Comment[] // Comments/interactions for this prospect

  service           String?
}

model Opportunity {
  id            String   @id @default(auto()) @map("_id") @db.ObjectId
  name          String
  phoneNumber   String?
  prevFollowup  DateTime?
  description   String?
  amount        Float?
  nextFollowUp  DateTime?
  status        String   @default("Proposal Issued") // "Proposal Issued", "Closed as Won", "Closed as Loss"
  prospectId    String   @db.ObjectId
  prospect      Prospect @relation("ProspectOpportunities", fields: [prospectId], references: [id])
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  comments      Comment[] // Comments/interactions for this opportunity
  quote         String?
}
datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-1.0.x"]
}

model User {
  id          String    @id @default(auto()) @map("_id") @db.ObjectId
  username    String    @unique // Used for both login and display
  email       String    @unique
  password    String
  adminType   String    @default("admin") // Either "owner" or "admin"
  status      String    @default("active") // "active" or "inactive"
  photo       String?
  lastLogin   DateTime?
  permissions String[]  @default([])
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  comments    Comment[] @relation("UserComments")

  // Task Category relations
  createdCategories  TaskCategory[] @relation("UserCreatedCategories")
  approvedCategories TaskCategory[] @relation("CategoryApprovals")
  rejectedCategories TaskCategory[] @relation("CategoryRejections")

  // Retainership relations
  createdRetainerships  Retainership[] @relation("UserCreatedRetainerships")
  approvedRetainerships Retainership[] @relation("RetainershipApprovals")
  rejectedRetainerships Retainership[] @relation("RetainershipRejections")

  // Service Records relation
  serviceRecords ServiceRecord[] @relation("UserServiceRecords")

  // OTP fields for password reset
  resetOtp            String?
  otpExpiry           DateTime?
  isOtpVerified       Boolean   @default(false)
  currentSessionToken String?
}

model Client {
  id                     String   @id @default(auto()) @map("_id") @db.ObjectId
  clientType             String
  email                  String   @unique
  phoneNumber            String
  secondaryPhoneNumber   String?
  address                String?
  preferredCommunication String?
  notes                  String?
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt
  tasks                  Task[]

  // Individual Fields
  firstName     String?
  lastName      String?
  gender        String?
  dateOfBirth   DateTime?
  idProofType   String?
  idProofNumber String?

  // Organization Fields
  organizationName     String?
  registrationNumber   String?
  entityType           String?
  incorporationDate    DateTime?
  gstNumber            String?
  authorizedPersonName String?
  designation          String?
  contactEmail         String?

  // Add this to the Client model
  retainerships Retainership[]
}

model Agent {
  id                   String    @id @default(auto()) @map("_id") @db.ObjectId
  name                 String
  email                String    @unique
  password             String // Authentication password field
  phoneNumber          String
  secondaryPhoneNumber String?
  agentType            String
  agentRole            String    @default("Execution Agent") // "Execution Agent" or "Advisor Agent"
  // For Advisor Agent, agentType can be: "Lead Maker", "Client Advisor", "Client Manager"
  // For Execution Agent, agentType can be: "CEO", "Partner", "Manager", etc. (existing types)
  barAssociationId     String
  jurisdiction         String
  specializations      String[]
  photo                String?
  status               String    @default("active") // "active" or "inactive"
  lastLogin            DateTime?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  // OTP fields for password reset
  resetOtp      String?
  otpExpiry     DateTime?
  isOtpVerified Boolean   @default(false)

  autoAssign           Boolean @default(true)

  // Team Management (multiple superiors via join table)
  superiorsLinks    AgentSuperior[] @relation("AgentSuperiors_superior")
  subordinatesLinks AgentSuperior[] @relation("AgentSuperiors_subordinate")
  createdTasks  Task[]    @relation("CreatedTasks")
  assignedTasks Task[]    @relation("AssignedTasks")
  ownerShipTasks Task[]    @relation("OwnerShipTasks")
  comments      Comment[] @relation("CommentAuthor")
  timeLogs      TimeLog[] @relation("TimeLogAgent")

  // TaskCategory agent-created relation
  createdCategories    TaskCategory[] @relation("AgentCreatedCategories")
  // Retainership agent-created relation
  createdRetainerships Retainership[] @relation("AgentCreatedRetainerships")
  currentSessionToken  String?

  // Legislation relations
  legislations Legislation[] @relation("AgentLegislations")

  // Prospects assigned to this agent
  assignedProspects Prospect[] @relation("AgentAssignedProspects")
  // Prospects created by this agent
  createdProspects Prospect[] @relation("AgentCreatedProspects")

  // Service Records relation
  serviceRecords ServiceRecord[] @relation("AgentServiceRecords")
  loginHistory   LoginHistory[]
  timesheetEntries TimesheetEntry[] @relation("TimesheetEntries")
}

model LoginHistory {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  agentId   String   @db.ObjectId
  agent     Agent    @relation(fields: [agentId], references: [id], onDelete: Cascade)

  ipAddress String?
  userAgent String?
  device    String?
  location  String?

  loginAt   DateTime @default(now())
  logoutAt  DateTime?

  createdAt DateTime @default(now())
}

model AgentSuperior {
  id            String @id @default(auto()) @map("_id") @db.ObjectId
  superiorId    String @db.ObjectId
  subordinateId String @db.ObjectId

  superior      Agent  @relation("AgentSuperiors_superior", fields: [superiorId], references: [id])
  subordinate   Agent  @relation("AgentSuperiors_subordinate", fields: [subordinateId], references: [id])
}

model Task {
  id               String    @id @default(auto()) @map("_id") @db.ObjectId
  title            String
  description      String?
  status           String    @default("To Do") // e.g., To Do, In Progress, Hold, Completed
  priority         String    @default("Medium") // e.g., Low, Medium, High
  dueDate          DateTime?
  progress         Int?      @default(0) // Progress percentage (0-100)
  followUpRequired Boolean   @default(false)
  followUpDuration     String? // e.g., "24hr", "48hr", "1w", "None"
  statusCheckDuration  String? // e.g., "24hr", "48hr", "1w", "None"
  completed        Boolean   @default(false)
  recurring        Int?      // Recurring in months (1-12), null means not recurring
  recurringType  String?  // 'DAY' | 'WEEK' | 'MONTH'
  holdDate         DateTime? 
  holdDaysLeft     Int?

  // New recurring tracking fields
  lastCompletedDate    DateTime? // When the current period was completed
  nextDueDate          DateTime? // When the next occurrence is due
  completionHistory    Json?     // Array of completion dates for tracking
  currentPeriodStart   DateTime? // Start of current recurring period

  // Optional field for recurring tasks
  triggerDate      DateTime?
   active           Boolean @default(true)

  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  clientId String? @db.ObjectId
  client   Client? @relation(fields: [clientId], references: [id])

  createdById String? @db.ObjectId
  createdBy   Agent?  @relation("CreatedTasks", fields: [createdById], references: [id])

  ownerShipId   String? @db.ObjectId
  ownerShipBy   Agent?  @relation("OwnerShipTasks", fields: [ownerShipId], references: [id])

  assignedToId String? @db.ObjectId
  assignedTo   Agent?  @relation("AssignedTasks", fields: [assignedToId], references: [id])

  categoryId String?       @db.ObjectId
  category   TaskCategory? @relation(fields: [categoryId], references: [id])

  // Legislation relation
  legislationId String?       @db.ObjectId
  legislation   Legislation?  @relation(fields: [legislationId], references: [id])

  comments Comment[]
  timeLogs TimeLog[]
  timesheetEntries TimesheetEntry[] @relation("TimesheetEntryTasks")

  // Add this to the Task model
  retainershipId String? @db.ObjectId
  retainership   Retainership? @relation("RetainershipTasks", fields: [retainershipId], references: [id])

  // Per-status progress tracking
  statusProgressMap Json?
}

model Legislation {
  id              String   @id @default(auto()) @map("_id") @db.ObjectId
  title           String
  description     String?
  assignedAgentId String?  @db.ObjectId
  assignedAgent   Agent?   @relation("AgentLegislations", fields: [assignedAgentId], references: [id])
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  // Relation to Retainership
  retainershipId String       @db.ObjectId
  retainership   Retainership @relation(fields: [retainershipId], references: [id], onDelete: Cascade)

  // Add tasks relation to fetch tasks based on legislation
  tasks Task[] @relation
}

model Retainership {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  name        String
  description String?
  color       String   @default("blue")
  status      String   @default("pending") // "pending" or "approved"
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Creator information (polymorphic: agent or user)
  createdByUserId  String? @db.ObjectId
  createdByUser    User?   @relation("UserCreatedRetainerships", fields: [createdByUserId], references: [id])
  createdByAgentId String? @db.ObjectId
  createdByAgent   Agent?  @relation("AgentCreatedRetainerships", fields: [createdByAgentId], references: [id])

  // Approval information
  approvedById String?   @db.ObjectId
  approvedBy   User?     @relation("RetainershipApprovals", fields: [approvedById], references: [id])
  approvedAt   DateTime?

  // Rejection information
  rejectedById    String?   @db.ObjectId
  rejectedBy      User?     @relation("RetainershipRejections", fields: [rejectedById], references: [id])
  rejectedAt      DateTime?
  rejectionReason String?

  // Tasks relation
  tasks Task[] @relation("RetainershipTasks")

  // Relation to Legislation
  legislation Legislation[]

  clientId String? @db.ObjectId
  client   Client? @relation(fields: [clientId], references: [id])
}

model Comment {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  content   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // File attachment fields
  attachmentName String?
  attachmentUrl  String?
  attachmentSize Int?
  attachmentType String?

  // Timesheet fields for task comments
  commentDate DateTime? // The date when the comment/work was done (defaults to createdAt if not provided)
  startTime   DateTime? // Start time of the work session
  endTime     DateTime? // End time of the work session

  taskId String? @db.ObjectId
  task   Task?   @relation(fields: [taskId], references: [id], onDelete: Cascade)
  prospectId   String? @db.ObjectId
  prospect     Prospect? @relation(fields: [prospectId], references: [id])
  opportunityId String? @db.ObjectId
  opportunity   Opportunity? @relation(fields: [opportunityId], references: [id])

  // Author can be either a User or an Agent
  authorId   String @db.ObjectId
  authorType String @default("USER") // "USER" or "AGENT"
  user       User?  @relation("UserComments", fields: [authorId], references: [id])
  agent      Agent? @relation("CommentAuthor", fields: [authorId], references: [id])
}

model TaskCategory {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  name        String
  description String?
  notes       String?
  processFlow String?
  color       String   @default("blue")
  status      String   @default("pending") // "pending" or "approved"
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Creator information (polymorphic: agent or user)
  createdByUserId  String? @db.ObjectId
  createdByUser    User?   @relation("UserCreatedCategories", fields: [createdByUserId], references: [id])
  createdByAgentId String? @db.ObjectId
  createdByAgent   Agent?  @relation("AgentCreatedCategories", fields: [createdByAgentId], references: [id])

  // Approval information
  approvedById String?   @db.ObjectId
  approvedBy   User?     @relation("CategoryApprovals", fields: [approvedById], references: [id])
  approvedAt   DateTime?

  // Rejection information
  rejectedById    String?   @db.ObjectId
  rejectedBy      User?     @relation("CategoryRejections", fields: [rejectedById], references: [id])
  rejectedAt      DateTime?
  rejectionReason String?

  // Tasks relation
  tasks Task[]

  // New optional field for time period in days
  timePeriod Int?

  /// If true, agents can edit the timePeriod (days) for this service
  agentCanEditDays Boolean @default(false)
}

model TimeLog {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  date        DateTime
  hours       Float
  description String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  taskId String @db.ObjectId
  task   Task   @relation(fields: [taskId], references: [id], onDelete: Cascade)

  agentId String @db.ObjectId
  agent   Agent  @relation("TimeLogAgent", fields: [agentId], references: [id])
}

model ServiceRecord {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  note      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  agentId String @db.ObjectId
  agent   Agent  @relation("AgentServiceRecords", fields: [agentId], references: [id], onDelete: Cascade)

  createdBy     String @db.ObjectId
  createdByUser User   @relation("UserServiceRecords", fields: [createdBy], references: [id])
}

model LeadSource {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  name        String   
  description String?

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  prospects   Prospect[]
}

model ProspectAssignmentSetting {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  prospectsPerAgent   Int  @default(1)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
}

model TimesheetEntry {
  id            String   @id @default(auto()) @map("_id") @db.ObjectId
  title         String
  description   String?
  project       String?
  projectCode   String?
  date          DateTime
  startTime     String   // HH:MM format
  endTime       String   // HH:MM format
  status        String   @default("pending") // pending, in-progress, completed, break
  type          String   @default("task") // task, login, logout
  color         String   @default("blue") // blue, yellow, coral, green
  
  agentId       String   @db.ObjectId
  agent         Agent    @relation("TimesheetEntries", fields: [agentId], references: [id], onDelete: Cascade)
  
  taskId        String?  @db.ObjectId
  task          Task?    @relation("TimesheetEntryTasks", fields: [taskId], references: [id], onDelete: SetNull)
  
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}