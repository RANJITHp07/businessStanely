# Backend-only WhatsApp service environment
WHATSAPP_SERVICE_TOKEN=change_me

# .env
PORT=4001
NODE_ENV=production
WHATSAPP_ALLOWED_ORIGIN=http://localhost:3000,http://localhost:3001
WHATSAPP_HEADLESS=true
WHATSAPP_SESSION_DIR=/home/ubuntu/whatsapp-session
WHATSAPP_CHROMIUM_EXECUTABLE_PATH=
WHATSAPP_USER_AGENT=
WHATSAPP_PROTOCOL_TIMEOUT_MS=180000

# Multi-user backpressure and bounded media caching
WHATSAPP_OPERATION_CONCURRENCY=12
WHATSAPP_OPERATION_QUEUE_LIMIT=200
WHATSAPP_OPERATION_QUEUE_TIMEOUT_MS=30000
WHATSAPP_MAX_MEDIA_BYTES=20971520
WHATSAPP_MEDIA_CACHE_TTL_MS=600000
WHATSAPP_MEDIA_CACHE_MAX_BYTES=134217728
WHATSAPP_MEDIA_CACHE_MAX_ENTRIES=100
